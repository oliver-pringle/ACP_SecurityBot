# Credentials — from https://app.virtuals.io/acp/agents/ → Signers tab
ACP_WALLET_ADDRESS=0x0000000000000000000000000000000000000000
ACP_WALLET_ID=
ACP_SIGNER_PRIVATE_KEY=0x

# Optional — from Settings tab
ACP_BUILDER_CODE=

# "base" for mainnet, "baseSepolia" for testnet
ACP_CHAIN=baseSepolia

# Inter-service URL.
# - Inside docker compose: http://securitybot-api:5000
# - Local dev (dotnet run + npm run dev): http://localhost:5000
SECURITYBOT_API_URL=http://securitybot-api:5000

# Optional shared secret between the sidecar and the C# API. When set on BOTH
# containers, the API requires X-API-Key on every non-/health request, and the
# sidecar forwards the same value. Leave blank to keep the boilerplate's
# private-network-only posture (no auth between containers). REQUIRED if you
# ever publish ports on securitybot-api directly.
SECURITYBOT_API_KEY=

# RPC URL the EIP-7702 delegation guard uses to probe the wallet's on-chain
# bytecode at boot. Defaults to publicnode if unset; override if you have a
# private / paid RPC. One eth_getBytecode call per boot — even free RPCs
# handle this fine.
BASE_RPC_URL=

# OPTIONAL sponsor key for EIP-7702 auto-recovery on boot. When set, the
# walletDelegation guard re-delegates the ACP wallet to Alchemy
# ModularAccountV2 via a sponsored type-4 tx if Privy WaaS has drifted to
# a different impl. Without it, the guard throws on drift with a recovery
# message pointing at scripts/provision-7702.ts. Keep this address funded
# with ~0.001 ETH for occasional gas. See acp-v2/src/walletDelegation.ts.
DEPLOYER_PRIVATE_KEY=
