# SecurityBot - C# API tier environment template.
# Copy to .env (gitignored) and fill in placeholders. NEVER commit a real .env.
# These are the env vars the SecurityBot.Api container reads. The ACP sidecar
# (acp-v2) has its own template at acp-v2/.env.example.

# REQUIRED in any non-Development environment. Program.cs fails fast at boot if
# ASPNETCORE_ENVIRONMENT != "Development" and this is empty. High-entropy random
# string, e.g. `openssl rand -hex 32`. The sidecar forwards this on every
# non-/health, non-/v1/resources call.
SECURITYBOT_API_KEY=

# REQUIRED in non-Development (audit F3). AES-256-GCM key for webhook_secret at
# rest. 32 bytes base64, e.g. `openssl rand -base64 32`. For a transitional
# plaintext deploy set SECURITYBOT_ALLOW_PLAINTEXT_WEBHOOK_SECRETS=true INSTEAD
# (the boot warns loudly).
WEBHOOK_SECRET_ENCRYPTION_KEY=

# OPTIONAL transitional escape hatch - ship webhook_secret plaintext at rest.
# Only honoured with a loud boot warning. Leave blank in real deploys.
SECURITYBOT_ALLOW_PLAINTEXT_WEBHOOK_SECRETS=

# Proactive-outreach kill-switch. SecurityBot ships NO outreach worker in v1;
# this default-OFF flag + the boot log keep the passive-auditor posture
# conscious. Any future cold-mail worker MUST gate on this. Leave false.
SECURITYBOT_OUTREACH_ENABLED=false

# OPTIONAL (audit F5). CIDR list of trusted reverse-proxy networks for
# X-Forwarded-For/-Proto. Behind Caddy on the droplet, tighten to the exact
# Caddy bridge subnet (e.g. 172.23.0.0/24). Empty => the in-code default
# 172.16.0.0/12,127.0.0.0/8,::1/128 (fine for local Docker).
TRUSTED_PROXY_NETWORKS=

# OPTIONAL Dev-only escape hatch - run with no X-API-Key even in Development.
# Refused in non-Development. Leave blank unless you really want unauth local dev.
# SECURITYBOT_ALLOW_UNAUTHENTICATED_DEV=true

# Dev/test only: granular webhook-validation relaxations. Refused at boot in
# non-Development. Leave blank in real deploys.
# ALLOW_HTTP_WEBHOOKS=true
# DISABLE_WEBHOOK_DNS_VALIDATION=true
# ALLOW_INSECURE_WEBHOOKS=true   # legacy alias for BOTH of the above; tests only

# OPTIONAL backup tuning (BackupWorker, daily WAL-aware online SQLite snapshot
# to /data/backups). Empty => Backup:HourUtc=4, Backup:KeepDays=7,
# Backup:Directory=/data/backups, Backup:Enabled=true. Set Backup__Enabled=false
# to disable.
# Backup__HourUtc=4
# Backup__KeepDays=7
